# Ignore Maven build output (built artifacts)
/target/

# Ensure IDE and editor folders are ignored
.idea/
*.iml
*.iws
*.ipr
.vscode/

# Eclipse
.settings/
.classpath
.project

# OS files
.DS_Store
Thumbs.db

# Logs and runtime files
*.log
*.tmp
*.pid
*.seed

# Compiled class files and archives
*.class
*.jar
*.war
*.ear

# Generated sources
/generated-sources/

# Node
node_modules/

# Environment files
.env
.env.local

# Docker
docker-compose.override.yml
.dockerignore

# Misc
*.swp
*.swo
.terraform/

# Keep local application.yml out of git if present in working dir
# (project already has application.yml in src/resources; only uncomment if you add a local override file)
#/application.yml.local
